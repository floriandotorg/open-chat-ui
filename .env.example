# Drizzle
DATABASE_URL=file:local.db

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Encryption key for API keys at rest (use 32+ random characters)
ENCRYPTION_SECRET=""

# Bun server idle timeout in seconds (max 255). Must exceed the longest quiet
# stretch in an SSE stream — i.e. slow first-token, file uploads, tool rounds.
# The chat stream sends a keepalive every 15s; this is the upper safety bound.
IDLE_TIMEOUT=120
